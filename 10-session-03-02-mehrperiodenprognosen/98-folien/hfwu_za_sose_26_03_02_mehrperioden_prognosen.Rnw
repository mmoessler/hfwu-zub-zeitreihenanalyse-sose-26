\section*{Einführung \& Motivation}



%..............................................................................
\begin{frame}
  \frametitle{Einführung \& Motivation}

  Warum Mehrperiodenprognosen?

  \begin{itemize}
    \item Viele Entscheidungen erfordern Prognosen über mehrere Perioden:
    \begin{itemize}
      \item Konjunktur- und Inflationsprognosen
      \item Unternehmensplanung und Budgetierung
      \item Finanzmarkt- und Risikoprognosen
    \end{itemize}

    \item Einperiodenprognosen reichen dafür oft nicht aus.

    \item Wie können wir Werte für $T+2$, $T+3$ oder noch weiter in der Zukunft prognostizieren?
  \end{itemize}

  % \vspace{0.5cm}

  Zwei grundlegende Ansätze:

  \begin{enumerate}
    \item Iterierte Mehrperiodenprognosen
    \item Direkte Mehrperiodenprognosen
  \end{enumerate}

\end{frame}
% Notes
\setbeamerfont{note page}{size=\small}
\note[itemize]{
  \item ...
}
%..............................................................................



\section*{Iterative Mehrperiodenprognosen}



%..............................................................................
\begin{frame}
  \frametitle{Iterative Mehrperiodenprognosen \hfill (1/4)}

  Einführung (generell)
  
  \begin{itemize}
    \item Prognosen bisher: ein Schritt in die Zukunft.
    \item Oft ist eine Prognose über mehrere Perioden notwendig.
    \item Zwei Hauptmethoden:
    \begin{itemize}
      \item Iterative Prognosen
      \item Direkte Prognosen
    \end{itemize}
    % \item Fokus: Iterative Mehrperiodenprognosen
  \end{itemize}  

  Grundidee der Iterativen Prognose
  
  \begin{itemize}
    % \item Schrittweise Vorhersage: Jede Prognose baut auf den zuvor berechneten Prognosen auf.
    \item Jede Prognose baut auf den zuvor berechneten Prognosen auf.
    \item Beispiel: Prognose für $T+2$ verwendet Prognose für $T+1$.
    \item Dieser Prozess wird so lange wiederholt, bis der gewünschte Horizont $h$ erreicht ist.
  \end{itemize}  

\end{frame}
% Notes
\setbeamerfont{note page}{size=\small}
\note[itemize]{
  \item ...
}
%..............................................................................



%..............................................................................
\begin{frame}
  \frametitle{Iterative Mehrperiodenprognosen \hfill (2/4)}

  Iterative AR(1)-Prognose
  \[
  \text{GDPGR}_t = 1.95 + 0.34 \cdot \text{GDPGR}_{t-1}
  \]
  
  \vspace{-0.25cm}
  
  \begin{itemize}
    \item Prognose für Q4 2017 mit Daten bis Q3 2017:
    \[
    \widehat{\text{GDPGR}}_{2017:Q4|2017:Q3} = 1.95 + 0.34 \cdot 3.11 = 3.0
    \]
    \item Prognose für Q1 2018:
    \[
    \widehat{\text{GDPGR}}_{2018:Q1|2017:Q3} = 1.95 + 0.34 \cdot 3.0 = 3.0
    \]
  \end{itemize}  

  Iterative AR(p)-Prognose
  \[
  \text{GDPGR}_t = 1.60 + 0.28 \cdot \text{GDPGR}_{t-1} + 0.18 \cdot \text{GDPGR}_{t-2}
  \]
  
  \vspace{-0.25cm}
  
  \begin{itemize}
    \item Prognose für Q1 2018:
    \[
    % \widehat{\text{GDPGR}}_{2018:Q1|2017:Q3} = 1.60 + 0.28 \cdot 3.0 + 0.18 \cdot 3.1 = 3.0
    \widehat{\text{GDPGR}}_{2018:Q1|2017:Q3} = 1.60 + 0.28 \cdot 3.01 + 0.18 \cdot 3.11 = 3.0
    \]
  \end{itemize}

\end{frame}
% Notes
\setbeamerfont{note page}{size=\small}
\note[itemize]{
  \item ...
}
%..............................................................................



