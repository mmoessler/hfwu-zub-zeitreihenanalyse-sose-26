% %..............................................................................
% \begin{frame}
%   \frametitle{Iterative Mehrperiodenprognosen \hfill (3/X)}
% 
%   % Iterative VAR-Prognose}
%   % 
%   % \begin{itemize}
%   %   \item Multivariat: Mehrere Variablen gleichzeitig (z.B. GDPGR, TSpread).
%   %   \item Prognose basiert auf vorhergesagten Werten aller Variablen.
%   %   \item Beispiel:
%   %   \begin{align*}
%   %   \hat{\text{GDPGR}}_{2018:Q1|2017:Q3} &= 0.54 + 0.29 \cdot 2.8 + 0.20 \cdot 3.1 \\
%   %   &\quad - 0.86 \cdot 1.3 + 1.28 \cdot 1.2 = 2.4
%   %   \end{align*}
%   % \end{itemize}
% 
%   Formeln für Iterative Prognosen
%   
%   Univariat (AR(p)):
%   \[
%   \hat{Y}_{T+2|T} = b_0 + b_1 \hat{Y}_{T+1|T} + b_2 Y_T + \ldots + b_p Y_{T-p+2}
%   \]
%   
%   Multivariat (VAR(p)):
%   \[
%   \hat{Y}_{T+2|T} = \sum_{i=1}^{p} A_i Y_{T+2-i} + \sum_{i=1}^{p} B_i X_{T+2-i}
%   \]
%   \begin{itemize}
%     \item Alle Koeffizienten sind OLS-Schätzungen.
%   \end{itemize}  
%     
%   Fazit
%   
%   \begin{itemize}
%     \item Iterative Prognosen sind bei vielen Anwendungen zuverlässiger.
%     \item Bieten konsistente Methodik für AR- und VAR-Modelle.
%     \item Für längere Horizonte sind Genauigkeit und Annahmen kritisch.
%   \end{itemize}  
%   
% \end{frame}
% % Notes
% \setbeamerfont{note page}{size=\small}
% \note[itemize]{
%   \item ...
% }
% %..............................................................................



%..............................................................................
\begin{frame}
  \frametitle{Iterative Mehrperiodenprognosen \hfill (4/4)}

  \metroset{block=fill}

  \begin{alertblock}{Schlüsselkonzept: Iterative Mehrperiodenprognosen}

  Die Iterative Mehrperiodenprognose mit einem AR-Modell wird schrittweise berechnet.
  
  Zuerst wird die Einperiodenprognose berechnet, anschließend daraus die Zweiperiodenprognose usw.
  
  Die Iterativen Zwei- und Dreiperiodenprognosen mit einem AR($p$)-Modell lauten:
  
  \vspace{-0.25cm}
  
  \begin{align*}
  \hat{Y}_{T+2|T} &= \hat{\beta}_0 + \hat{\beta}_1 \hat{Y}_{T+1|T} + \hat{\beta}_2 Y_T + \hat{\beta}_3 Y_{T-1} + \cdots + \hat{\beta}_p Y_{T-p+2} \\
  \hat{Y}_{T+3|T} &= \hat{\beta}_0 + \hat{\beta}_1 \hat{Y}_{T+2|T} + \hat{\beta}_2 \hat{Y}_{T+1|T} + \hat{\beta}_3 Y_T + \cdots + \hat{\beta}_p Y_{T-p+3} \\
  \cdots
  \end{align*}
  
  \vspace{-0.25cm}
  
  Dabei sind die $\hat{\beta}$ die OLS-Schätzwerte der AR($p$)-Koeffizienten.
  
  Durch Wiederholung dieses Verfahrens erhält man Prognosen für noch weiter entfernte Zeitpunkte.
  
  % \vspace{0.5em}
  % Die Iterative Mehrperiodenprognose mit einem VAR-Modell erfolgt analog: Zuerst werden Einperiodenprognosen für alle Variablen im VAR berechnet. Diese Prognosen dienen als Grundlage für die Zweiperiodenprognose usw.
  % 
  % Die Iterative Zweiperiodenprognose für $Y_{T+2}$ aus einem VAR($p$)-Modell mit zwei Variablen lautet:
  % 
  % \begin{align*}
  % \hat{Y}_{T+2|T} = & \; \hat{\beta}_{10} + \hat{\beta}_{11} \hat{Y}_{T+1|T} + \hat{\beta}_{12} Y_T + \hat{\beta}_{13} Y_{T-1} + \cdots + \hat{\beta}_{1p} Y_{T-p+2} \\
  % & + \hat{\gamma}_{11} \hat{X}_{T+1|T} + \hat{\gamma}_{12} X_T + \hat{\gamma}_{13} X_{T-1} + \cdots + \hat{\gamma}_{1p} X_{T-p+2}
  % \end{align*}
  % 
  % Die Koeffizienten in dieser Gleichung sind OLS-Schätzungen aus dem VAR-Modell. Die iterative Anwendung liefert Prognosen für beliebig viele Perioden in der Zukunft.

	\end{alertblock}
  
\end{frame}
% Notes
\setbeamerfont{note page}{size=\small}
\note[itemize]{
  \item ...
}
